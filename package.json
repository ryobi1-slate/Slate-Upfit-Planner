    "format": "wp-scripts format assets/src"
  },
  "dependencies": {
    "@wordpress/element": "^5.35.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@wordpress/scripts": "^27.9.0",
    "ajv": "^8.20.0",
    "typescript": "^5.4.5"
  }
}
