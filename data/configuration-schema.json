{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slatebuilt.com/schemas/upfit-planner-configuration-1.0.json",
  "title": "Slate Upfit Planner Configuration",
  "description": "Versioned normalized configuration payload exchanged between the planner, WordPress REST, and the host adapter. This is the single source of truth for save and quote handoff.",
  "type": "object",
  "required": [
    "schema_version",
    "configuration_id",
    "vehicle",
    "placements",
    "infrastructure",
    "exterior_equipment",
    "validation",
    "totals",
    "dealer_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Schema contract version. Bump on breaking changes."
    },
    "configuration_id": {
      "type": ["string", "null"],
      "description": "Host/local identifier once saved; null while unsaved."
    },
    "vehicle": {
      "type": "object",
      "description": "Selected vehicle and geometry reference.",
      "required": ["id", "name", "wheelbase", "wall"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "wheelbase": { "type": "string", "minLength": 1 },
        "wall": { "enum": ["driver", "passenger", null] }
      },
      "additionalProperties": false
    },
    "placements": {
      "type": "array",
      "description": "Placed components with their positions on a wall/zone.",
      "items": {
        "type": "object",
        "required": ["id", "sku", "wall", "position"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "sku": {
            "enum": ["22-3436", "22-3437", "22-3438", "22-3439", "22-3440"]
          },
          "wall": { "enum": ["driver", "passenger"] },
          "position": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number", "minimum": 0 },
              "y": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "infrastructure": {
      "type": "array",
      "description": "Electrical, power, and structural infrastructure items.",
      "items": { "type": "object" }
    },
    "exterior_equipment": {
      "type": "array",
      "description": "Exterior-mounted equipment (racks, ladders, awnings).",
      "items": { "type": "object" }
    },
    "validation": {
      "type": "array",
      "description": "Fitment issues surfaced by the engine (errors/warnings/info).",
      "items": { "type": "object" }
    },
    "totals": {
      "type": "object",
      "description": "Roll-up totals (wall usage, payload, package value).",
      "properties": {
        "wall_usage": { "type": "object" },
        "payload": { "type": "object" },
        "package_value": { "type": ["number", "null"] }
      },
      "required": ["wall_usage", "payload", "package_value"],
      "additionalProperties": false
    },
    "dealer_notes": {
      "type": "string",
      "maxLength": 5000
    }
  },
  "additionalProperties": false
}
