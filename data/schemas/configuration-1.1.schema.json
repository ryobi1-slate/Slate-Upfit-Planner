{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://slatebuilt.com/schemas/configuration-1.1.schema.json", "title": "Slate Upfit Planner Configuration 1.1",
  "type": "object", "required": ["schema_version", "configuration_id", "vehicle", "placements", "infrastructure", "exterior_equipment", "validation", "totals", "dealer_notes", "catalog_revisions", "package_origin", "unplaced_items", "engineering_data"],
  "properties": {
    "schema_version": { "const": "1.1" }, "configuration_id": { "type": ["string", "null"] },
    "vehicle": { "type": "object", "required": ["id", "name", "wheelbase", "wall", "geometry_revision"], "properties": { "id": { "type": "string", "minLength": 1 }, "name": { "type": "string", "minLength": 1 }, "wheelbase": { "type": "string", "minLength": 1 }, "wall": { "enum": ["driver", "passenger", null] }, "geometry_revision": { "type": ["string", "null"], "minLength": 1 } }, "additionalProperties": false },
    "placements": { "type": "array", "items": { "type": "object", "required": ["id", "sku", "wall", "position"], "properties": { "id": { "type": "string", "minLength": 1 }, "sku": { "type": "string", "minLength": 1 }, "wall": { "enum": ["driver", "passenger"] }, "position": { "type": "object", "required": ["x", "y"], "properties": { "x": { "type": "number", "minimum": 0 }, "y": { "type": "number", "minimum": 0 } }, "additionalProperties": false } }, "additionalProperties": false } },
    "infrastructure": { "type": "array", "items": { "type": "object" } }, "exterior_equipment": { "type": "array", "items": { "type": "object" } }, "validation": { "type": "array", "items": { "type": "object" } },
    "totals": { "type": "object", "required": ["wall_usage", "payload", "package_value"], "properties": { "wall_usage": { "type": "object" }, "payload": { "type": "object" }, "package_value": { "type": ["number", "null"] } }, "additionalProperties": false }, "dealer_notes": { "type": "string", "maxLength": 5000 },
    "catalog_revisions": { "type": "array", "items": { "type": "object", "required": ["manufacturer", "sku", "revision", "status"], "properties": { "manufacturer": { "type": "string", "minLength": 1 }, "sku": { "type": "string", "minLength": 1 }, "revision": { "type": ["string", "null"], "minLength": 1 }, "status": { "enum": ["resolved", "unresolved"] } }, "additionalProperties": false } },
    "package_origin": { "type": ["object", "null"], "properties": { "package_id": { "type": "string", "minLength": 1 }, "package_revision": { "type": "string", "minLength": 1 }, "baseline_fingerprint": { "type": "string", "minLength": 1 }, "divergence": { "type": "object", "required": ["status", "added_placement_ids", "removed_component_refs", "quantity_changes", "position_changes", "surface_changes"], "properties": { "status": { "enum": ["aligned", "diverged"] }, "added_placement_ids": { "type": "array", "items": { "type": "string" } }, "removed_component_refs": { "type": "array", "items": { "type": "string" } }, "quantity_changes": { "type": "array", "items": { "type": "object" } }, "position_changes": { "type": "array", "items": { "type": "object" } }, "surface_changes": { "type": "array", "items": { "type": "object" } } }, "additionalProperties": false } }, "required": ["package_id", "package_revision", "baseline_fingerprint", "divergence"], "additionalProperties": false },
    "unplaced_items": { "type": "array", "items": { "type": "object", "required": ["sku", "requirement", "reason_code"], "properties": { "sku": { "type": "string", "minLength": 1 }, "requirement": { "enum": ["required", "optional"] }, "reason_code": { "type": "string", "minLength": 1 } }, "additionalProperties": false } },
    "engineering_data": { "type": "object", "required": ["status", "geometry_revision_status", "catalog_revision_status"], "properties": { "status": { "enum": ["resolved", "partially_resolved", "unresolved"] }, "geometry_revision_status": { "enum": ["resolved", "unresolved"] }, "catalog_revision_status": { "enum": ["resolved", "unresolved"] } }, "additionalProperties": false }
  }, "additionalProperties": false
}
