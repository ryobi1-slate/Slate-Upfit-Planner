{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slatebuilt.com/schemas/engineering-data-envelope-1.0.schema.json",
  "title": "Engineering Data Envelope 1.0",
  "type": "object",
  "required": ["schema_version", "metadata", "data"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "metadata": { "$ref": "#/$defs/provenance" },
    "data": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "nullableIdentity": { "type": ["string", "null"], "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["title", "reference", "retrieved_on"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "reference": { "type": ["string", "null"], "minLength": 1 },
        "retrieved_on": { "type": ["string", "null"], "format": "date" }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["record_revision", "approval_state", "source", "prepared_by", "verified_by", "approved_by", "last_verified", "change_summary"],
      "properties": {
        "record_revision": { "type": "string", "minLength": 1 },
        "approval_state": { "enum": ["draft", "verified", "approved", "deprecated", "rejected"] },
        "source": { "$ref": "#/$defs/source" },
        "prepared_by": { "$ref": "#/$defs/nullableIdentity" },
        "verified_by": { "$ref": "#/$defs/nullableIdentity" },
        "approved_by": { "$ref": "#/$defs/nullableIdentity" },
        "last_verified": { "type": ["string", "null"], "format": "date" },
        "change_summary": { "type": "string", "minLength": 1 }
      },
      "allOf": [{
        "if": { "properties": { "approval_state": { "const": "approved" } }, "required": ["approval_state"] },
        "then": {
          "properties": {
            "source": { "properties": { "reference": { "type": "string", "minLength": 1 }, "retrieved_on": { "type": "string", "format": "date" } } },
            "prepared_by": { "type": "string", "minLength": 1 },
            "verified_by": { "type": "string", "minLength": 1 },
            "approved_by": { "type": "string", "minLength": 1 },
            "last_verified": { "type": "string", "format": "date" }
          }
        }
      }],
      "additionalProperties": false
    },
    "measurement": {
      "type": "object",
      "required": ["value", "unit", "status"],
      "properties": {
        "value": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "unit": { "enum": ["in", "lb", "hours"] },
        "status": { "enum": ["verified", "unverified", "estimated", "pending", "not_applicable"] }
      },
      "allOf": [
        { "if": { "properties": { "status": { "const": "pending" } }, "required": ["status"] }, "then": { "properties": { "value": { "type": "null" } } } },
        { "if": { "properties": { "status": { "enum": ["verified", "unverified", "estimated"] } }, "required": ["status"] }, "then": { "properties": { "value": { "type": "number", "exclusiveMinimum": 0 } } } },
        { "if": { "properties": { "status": { "const": "not_applicable" } }, "required": ["status"] }, "then": { "properties": { "value": { "type": "null" } } } }
      ],
      "additionalProperties": false
    }
  }
}
