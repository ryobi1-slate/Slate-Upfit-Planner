{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slatebuilt.com/schemas/catalog-product-1.0.schema.json",
  "title": "Catalog Product 1.0",
  "allOf": [{ "$ref": "engineering-data-envelope-1.0.schema.json" }],
  "properties": {
    "schema_version": { "const": "1.0" },
    "data": {
      "type": "object",
      "required": ["manufacturer", "sku", "product_name", "description", "category", "subcategory", "dimensions", "published_weight", "estimated_install_hours", "placement_surface", "placement_mode", "supported_vehicle_rule_ids", "supported_roof_rules", "required_clearances", "required_accessories", "excluded_products", "required_products", "quantity_limits", "product_family", "lifecycle_status", "data_revision"],
      "properties": {
        "manufacturer": { "type": "string", "minLength": 1 }, "sku": { "type": "string", "minLength": 1 }, "product_name": { "type": "string", "minLength": 1 }, "description": { "type": "string" }, "category": { "type": "string", "minLength": 1 }, "subcategory": { "type": "string", "minLength": 1 },
        "dimensions": { "type": "object", "required": ["length", "depth", "height"], "properties": { "length": { "$ref": "engineering-data-envelope-1.0.schema.json#/$defs/measurement" }, "depth": { "$ref": "engineering-data-envelope-1.0.schema.json#/$defs/measurement" }, "height": { "$ref": "engineering-data-envelope-1.0.schema.json#/$defs/measurement" } }, "additionalProperties": false },
        "published_weight": { "$ref": "engineering-data-envelope-1.0.schema.json#/$defs/measurement" }, "estimated_install_hours": { "$ref": "engineering-data-envelope-1.0.schema.json#/$defs/measurement" },
        "placement_surface": { "type": "array", "items": { "enum": ["driver_wall", "passenger_wall"] }, "uniqueItems": true }, "placement_mode": { "enum": ["wall_mounted", "pending"] },
        "supported_vehicle_rule_ids": { "$ref": "#/$defs/stringList" }, "supported_roof_rules": { "$ref": "#/$defs/stringList" }, "required_clearances": { "$ref": "#/$defs/stringList" }, "required_accessories": { "$ref": "#/$defs/stringList" }, "excluded_products": { "$ref": "#/$defs/stringList" }, "required_products": { "$ref": "#/$defs/stringList" },
        "quantity_limits": { "type": "object", "required": ["minimum", "maximum"], "properties": { "minimum": { "type": "integer", "minimum": 0 }, "maximum": { "type": ["integer", "null"], "minimum": 1 } }, "additionalProperties": false },
        "product_family": { "type": "string", "minLength": 1 }, "lifecycle_status": { "enum": ["draft", "active", "deprecated"] }, "data_revision": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": { "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true } }
}
