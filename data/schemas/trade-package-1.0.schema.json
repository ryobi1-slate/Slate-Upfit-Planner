{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://slatebuilt.com/schemas/trade-package-1.0.schema.json", "title": "Trade Package 1.0",
  "allOf": [{ "$ref": "engineering-data-envelope-1.0.schema.json" }],
  "properties": { "schema_version": { "const": "1.0" }, "data": {
    "type": "object", "required": ["package_id", "package_name", "revision", "description", "supported_vehicle_ids", "compatibility_rule_ids", "components", "fallback_rules", "install_estimate", "lifecycle_status"],
    "properties": {
      "package_id": { "type": "string", "minLength": 1 }, "package_name": { "type": "string", "minLength": 1 }, "revision": { "type": "string", "minLength": 1 }, "description": { "type": "string" },
      "supported_vehicle_ids": { "$ref": "#/$defs/stringList" }, "compatibility_rule_ids": { "$ref": "#/$defs/stringList" },
      "components": { "type": "array", "items": { "type": "object", "required": ["component_id", "sku", "requirement", "quantity", "preferred_surface", "placement_order", "fallback_rule_ids", "compatibility_rule_ids"], "properties": { "component_id": { "type": "string", "minLength": 1 }, "sku": { "type": "string", "minLength": 1 }, "requirement": { "enum": ["required", "optional"] }, "quantity": { "type": "integer", "minimum": 1 }, "preferred_surface": { "enum": ["driver_wall", "passenger_wall", "any"] }, "placement_order": { "type": "integer", "minimum": 0 }, "fallback_rule_ids": { "$ref": "#/$defs/stringList" }, "compatibility_rule_ids": { "$ref": "#/$defs/stringList" } }, "additionalProperties": false } },
      "fallback_rules": { "$ref": "#/$defs/stringList" }, "install_estimate": { "$ref": "engineering-data-envelope-1.0.schema.json#/$defs/measurement" }, "lifecycle_status": { "enum": ["draft", "active", "deprecated"] }
    }, "additionalProperties": false
  } },
  "$defs": { "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true } }
}
